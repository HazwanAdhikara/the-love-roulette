# Directories that Ren'Py changes files in.
/game/saves
/game/cache

# Explicit project-local ignores requested for this repo.
game/saves/
game/cache/

# Compiled script files. These are important for saving, and so should
# be preserved by developer and build systems after the game has been released.
/game/**/*.rpyc
/game/**/*.rpymc
*.rpyc
*.rpyb
*.rpymc

# Files Ren'Py can generate.
/game/**/*.bak
/game/**/*.new
/game/**/*.old

# Error, log, and output files.
/errors.txt
/files.txt
/image_cache.txt
/log.txt
/save_dump.txt
/traceback.txt
log.txt

# macOS system files.
.DS_Store

# Launcher-generated files.
/dialogue.tab
/dialogue.txt
/strings.json
